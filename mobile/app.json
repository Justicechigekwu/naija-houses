{
  "expo": {
    "name": "Velora",
    "slug": "velora-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/android-chrome-512x512.png",
    "scheme": "velora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.velora.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-chrome-512x512.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      "expo-web-browser",
      "expo-notifications",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F5F5",
          "image": "./assets/images/velora-logo.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0F1115",
            "image": "./assets/images/velora-logo.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6dfbcc38-be39-4cf0-b9ea-082e159b87bf"
      }
    },
    "owner": "justicechigekwu"
  }
}
